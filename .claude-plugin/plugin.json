{
  "name": "flutter-slipstream",
  "version": "1.4.0",
  "description": "Live Flutter app introspection for coding agents: screenshots, widget-tree inspection, tap/type/scroll, and error capture. Dart package API summarization for agents.",
  "repository": "https://github.com/devoncarew/flutter-slipstream",
  "license": "BSD-3-Clause license",
  "keywords": ["dart", "flutter"],
  "mcpServers": {
    "inspector": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inspector_mcp.sh",
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "packages": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/packages_mcp.sh",
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(flutter pub add *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/deps_check_claude.sh --mode=pub-add",
            "description": "Validates packages before flutter pub add runs",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*pubspec.yaml)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/deps_check_claude.sh --mode=pubspec-guard",
            "description": "Validates packages on direct pubspec.yaml edits",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*pubspec.yaml)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/deps_check_claude.sh --mode=pubspec-guard",
            "description": "Validates packages on direct pubspec.yaml edits",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ]
  }
}
