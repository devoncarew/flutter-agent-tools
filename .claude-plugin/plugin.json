{
  "name": "flutter-slipstream",
  "version": "1.1.0",
  "description": "Flutter/Dart agent tooling: package API summarization and runtime UI introspection.",
  "repository": "https://github.com/devoncarew/flutter-slipstream",
  "license": "BSD-3-Clause license",
  "keywords": ["dart", "flutter"],
  "mcpServers": {
    "inspector": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inspector_mcp.sh",
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "packages": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/packages_mcp.sh",
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/deps_check.sh --mode=pub-add",
            "description": "Validates packages before flutter pub add runs",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/deps_check.sh --mode=pubspec-guard",
            "description": "Validates packages on direct pubspec.yaml edits",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ]
  }
}
