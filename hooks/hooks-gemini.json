{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "deps-check-pub-add",
            "type": "command",
            "command": "node ${extensionPath}/scripts/deps_check.js --agent=gemini --mode=pub-add",
            "description": "Validates packages before flutter pub add runs"
          }
        ]
      },
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "deps-check-pubspec-guard",
            "type": "command",
            "command": "node ${extensionPath}/scripts/deps_check.js --agent=gemini --mode=pubspec-guard",
            "description": "Validates packages on direct pubspec.yaml edits"
          }
        ]
      }
    ]
  }
}
