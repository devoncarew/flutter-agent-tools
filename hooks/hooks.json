{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/dep_health_check.sh",
            "description": "Validates packages before flutter pub add runs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pubspec_guard.sh",
            "description": "Guards direct pubspec.yaml dependency edits"
          }
        ]
      }
    ]
  }
}
