{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/start_dep_check.sh --mode=pub-add",
            "description": "Validates packages before flutter pub add runs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/start_dep_check.sh --mode=pubspec-guard",
            "description": "Validates packages on direct pubspec.yaml edits"
          }
        ]
      }
    ]
  }
}
